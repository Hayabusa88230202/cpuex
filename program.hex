3c10ffff  // lui $s0, 0xffff (UARTアドレス)
20080099  // addi $t0, $zero, 0x99
ae080000  // sw $t0, 0($s0) (PCへ 0x99 を送信)
8e090000  // lw $t1, 0($s0) (★PCから送られてくるプログラムの「合計サイズ」を32ビットで一発受信！)
3c110004  // lui $s1, 0x0004 (展開先: 0x00040000)
8e0a0000  // [Loop開始] lw $t2, 0($s0) (★プログラムの命令を32ビットで一発受信！)
ae2a0000  // sw $t2, 0($s1) (DRAMに書き込み)
22310004  // addi $s1, $s1, 4 (アドレスを+4)
2129fffc  // addi $t1, $t1, -4 (残りのサイズを-4)
1520fffb  // bne $t1, $zero, Loopへ戻る
200800aa  // addi $t0, $zero, 0xaa
ae080000  // sw $t0, 0($s0) (PCへ 0xaa を送信)
3c1d06ff  // ★追加: lui $sp, 0x06ff
37bdfffc  // ★追加: ori $sp, $sp, 0xfffc (この2行で $sp = 0x06FFFFFC に設定！)
3c110004  // lui $s1, 0x0004
02200008  // jr $s1 (レイトレプログラムへジャンプ！)